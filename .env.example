# TestPilot — root .env.example
# Copy to .env and fill in values. NEVER commit .env to git.
# Each PoC backend has its own .env.example — copy this or the PoC-level one.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Required. Rotate after sprint ends.

# ── Model selection ───────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6        # Default. Use claude-opus-4-7 only for complex reasoning.

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./outputs                  # Relative to each PoC backend directory.

# ── Reliability ───────────────────────────────────────────────────────────────
MAX_RETRIES=2                         # Anthropic API retry count (exponential backoff).

# ── CORS (frontend origin) ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000    # Comma-separated for multiple origins.

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
